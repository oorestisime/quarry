{
  "name": "quarry-workspace",
  "version": "0.2.0",
  "private": true,
  "description": "Experimental ClickHouse-native query builder for TypeScript.",
  "keywords": [
    "analytics",
    "clickhouse",
    "columnar",
    "query",
    "query builder",
    "query-builder",
    "sql",
    "type-safe",
    "type-safety",
    "typescript"
  ],
  "homepage": "https://github.com/oorestisime/quarry",
  "bugs": {
    "url": "https://github.com/oorestisime/quarry/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/oorestisime/quarry.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @oorestisime/quarry build",
    "build:cli": "pnpm build && pnpm --filter @oorestisime/quarry-cli build",
    "cli": "pnpm exec tsx packages/cli/src/index.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm --filter @oorestisime/quarry lint && pnpm --filter @oorestisime/quarry-cli lint",
    "lint:fix": "pnpm --filter @oorestisime/quarry lint:fix && pnpm --filter @oorestisime/quarry-cli lint:fix",
    "publish:core": "pnpm --filter @oorestisime/quarry publish",
    "test": "pnpm --filter @oorestisime/quarry test && pnpm --filter @oorestisime/quarry-cli test",
    "test:coverage": "pnpm --filter @oorestisime/quarry test:coverage",
    "test:integration": "pnpm --filter @oorestisime/quarry test:integration",
    "test:watch": "pnpm --filter @oorestisime/quarry test:watch",
    "typecheck": "pnpm --filter @oorestisime/quarry typecheck && pnpm --filter @oorestisime/quarry-cli typecheck",
    "typecheck:docs": "pnpm --filter @oorestisime/quarry-docs typecheck"
  },
  "devDependencies": {
    "@clickhouse/client": "^1.18.2",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "testcontainers": "^11.13.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
